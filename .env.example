# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=ctrlvalue
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_me_at_least_32_chars_long_random_string
JWT_ISSUER=ctrlvalue
JWT_AUDIENCE=ctrlvalue
JWT_EXPIRY_MINUTES=60

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256 key, base64-encoded 32 bytes. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ── Frontend URL (used in email links and CORS) ───────────────────────────────
FRONTEND_URL=http://localhost

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@ctrlvalue.local
EMAIL_FROM_NAME=CtrlValue

# ── AI Providers (optional — leave blank to disable) ─────────────────────────
AGENT_PROVIDER=OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# ── Azure Key Vault (optional — leave blank for Docker/self-hosted) ───────────
# KEY_VAULT_URI=https://your-vault.vault.azure.net/
