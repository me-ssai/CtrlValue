<div class="page-container">
    <div class="page-header">
        <h1><mat-icon>swap_horiz</mat-icon> Transactions</h1>

        <div class="header-actions">
            <button mat-stroked-button color="warn" *ngIf="selectedCount > 0" [disabled]="deletingBulk"
                (click)="bulkDeleteTransactions()">
                <mat-icon>delete_sweep</mat-icon>
                Delete Selected ({{ selectedCount }})
            </button>

            <button mat-stroked-button (click)="openImportDialog()" id="importQifBtn">
                <mat-icon>upload_file</mat-icon> Import QIF
            </button>

            <button mat-stroked-button (click)="openOfxImportDialog()" id="importOfxBtn">
                <mat-icon>upload_file</mat-icon> Import OFX
            </button>

            <button mat-raised-button color="primary" (click)="createTransaction()">
                <mat-icon>add</mat-icon> Add Transaction
            </button>
        </div>
    </div>

    <div class="loading" *ngIf="loading">
        <mat-icon>refresh</mat-icon> Loading transactions...
    </div>

    <div class="empty-state" *ngIf="!loading && dataSource.data.length === 0">
        <mat-icon>swap_horiz</mat-icon>
        <h3>No Transactions</h3>
        <p>Start tracking your income and expenses.</p>
        <button mat-raised-button color="primary" (click)="createTransaction()">
            <mat-icon>add</mat-icon> Add Transaction
        </button>
    </div>

    <div class="table-container" *ngIf="!loading && dataSource.data.length > 0">
        <table mat-table [dataSource]="dataSource" matSort class="w-100">

            <!-- Select Column -->
            <ng-container matColumnDef="select">
                <th mat-header-cell *matHeaderCellDef>
                    <mat-checkbox (change)="toggleAllRows()" [checked]="isAllSelected()"
                        [indeterminate]="selection.hasValue() && !isAllSelected()" [aria-label]="checkboxLabel()">
                    </mat-checkbox>
                </th>
                <td mat-cell *matCellDef="let transaction">
                    <mat-checkbox (click)="$event.stopPropagation()" (change)="toggleRow(transaction)"
                        [checked]="selection.isSelected(transaction)" [aria-label]="checkboxLabel(transaction)">
                    </mat-checkbox>
                </td>
            </ng-container>

            <!-- Date Column -->
            <ng-container matColumnDef="date">
                <th mat-header-cell *matHeaderCellDef mat-sort-header>Date</th>
                <td mat-cell *matCellDef="let transaction">{{ transaction.txnTime | date:'dd/MM/yyyy' }}</td>
            </ng-container>

            <!-- Type Column -->
            <ng-container matColumnDef="type">
                <th mat-header-cell *matHeaderCellDef mat-sort-header>Type</th>
                <td mat-cell *matCellDef="let transaction">
                    <mat-chip [class]="getTypeClass(transaction.txnType) + '-chip'">
                        {{ transaction.txnType }}
                    </mat-chip>
                </td>
            </ng-container>

            <!-- Category Column -->
            <ng-container matColumnDef="category">
                <th mat-header-cell *matHeaderCellDef mat-sort-header>Category</th>
                <td mat-cell *matCellDef="let transaction">{{ transaction.categoryName }}</td>
            </ng-container>

            <!-- Amount Column -->
            <ng-container matColumnDef="amount">
                <th mat-header-cell *matHeaderCellDef mat-sort-header>Amount</th>
                <td mat-cell *matCellDef="let transaction" class="fw-bold" [class]="getTypeClass(transaction.txnType)">
                    {{ transaction.amount | currency:transaction.currency:'symbol':'1.2-2' }}
                </td>
            </ng-container>

            <!-- Currency Column -->
            <ng-container matColumnDef="currency">
                <th mat-header-cell *matHeaderCellDef mat-sort-header>Currency</th>
                <td mat-cell *matCellDef="let transaction">{{ transaction.currency }}</td>
            </ng-container>

            <!-- Description Column -->
            <ng-container matColumnDef="description">
                <th mat-header-cell *matHeaderCellDef>Description</th>
                <td mat-cell *matCellDef="let transaction" class="description-cell text-muted">
                    {{ transaction.description || '—' }}
                </td>
            </ng-container>

            <!-- Tags Column -->
            <ng-container matColumnDef="tags">
                <th mat-header-cell *matHeaderCellDef>Tags</th>
                <td mat-cell *matCellDef="let transaction">
                    <mat-chip-listbox *ngIf="transaction.tags">
                        <mat-chip *ngFor="let tag of transaction.tags.split(',')">
                            {{ tag.trim() }}
                        </mat-chip>
                    </mat-chip-listbox>
                    <span *ngIf="!transaction.tags" class="text-muted">—</span>
                </td>
            </ng-container>

            <!-- Actions Column -->
            <ng-container matColumnDef="actions">
                <th mat-header-cell *matHeaderCellDef>Actions</th>
                <td mat-cell *matCellDef="let transaction" class="actions-cell">
                    <button mat-icon-button color="primary" (click)="editTransaction(transaction.id)"
                        matTooltip="Edit transaction">
                        <mat-icon>edit</mat-icon>
                    </button>

                    <button mat-icon-button color="warn" (click)="deleteTransaction(transaction.id)"
                        matTooltip="Delete transaction">
                        <mat-icon>delete</mat-icon>
                    </button>
                </td>
            </ng-container>

            <tr mat-header-row *matHeaderRowDef="displayedColumns"></tr>
            <tr mat-row *matRowDef="let row; columns: displayedColumns;"
                [class.selected-row]="selection.isSelected(row)">
            </tr>
        </table>

        <mat-paginator [pageSizeOptions]="[5, 10, 25, 100]" showFirstLastButtons>
        </mat-paginator>
    </div>
</div>